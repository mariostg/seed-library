# Copy this file to scripts/.env.media-archive on the server and adjust values.
# This example is safe to keep in git.

# Backup destination host (public IP or DNS)
IP=XXX.XXX.XXX.XXX

# Optional SSH user for the destination server ($IP)
SSH_USER=django

# Destination directory on the remote server ($IP)
BACKUP_FOLDER=/home/django/backups/owsl/media-archives

# Optional retention policy
RETENTION_DAYS=30
RETENTION_COUNT=60

# Optional logging/locking
# LOG_FILE=/home/mariost-gelais/catalogue.wildflowerseedlibrary.ca/logs/media-archive-backup.log
# LOCK_FILE=/tmp/owsl-media-archive-backup.lock
